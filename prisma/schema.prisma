datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

model users {
  id                 String       @id @default(uuid()) @db.Uuid
  email              String?      @unique @db.VarChar(255)
  encrypted_password String?      @db.VarChar(255)
  email_confirmed_at DateTime?    @db.Timestamptz(6)
  is_sso_user        Boolean      @default(false)
  profiles           profiles?
  items              items[]      @relation("SellerItems")
  messages           messages[]
  cart_items         cart_items[]
  user_activity      user_activity[]
}

model profiles {
  id                         String    @id @default(uuid()) @db.Uuid
  user_id                    String?   @unique @db.Uuid
  full_name                  String?   @db.VarChar(255)
  avatar_url                 String?   @db.VarChar(255)
  email                      String    @unique @db.VarChar(255)
  role                       String    @default("user") @db.VarChar(50)
  telegram_id                String?   @unique @db.VarChar(64)
  telegram_username          String?   @db.VarChar(255)
  created_at                 DateTime? @default(now()) @db.Timestamptz(6)
  last_active_at             DateTime? @db.Timestamptz(6)
  phone                      String?   @db.VarChar(32)
  preferred_location         String?   @db.VarChar(255)
  email_notifications_enabled Boolean? @default(true)
  users                      users     @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  telegram_bind_codes        telegram_bind_code[]
}

model telegram_bind_code {
  code       String   @id @db.VarChar(32)
  profile_id String   @db.Uuid
  expires_at DateTime @db.Timestamptz(6)
  profiles   profiles @relation(fields: [profile_id], references: [id], onDelete: Cascade)
}

model items {
  id          String    @id @default(uuid()) @db.Uuid
  seller_id   String    @db.Uuid
  title       String    @db.VarChar(255)
  description String?   @db.Text
  price       Decimal   @db.Decimal(10, 2)
  location    String?   @db.VarChar(255)
  image_url   String?   @db.VarChar(255)
  image_urls  String[]
  status      String    @default("available") @db.VarChar(50)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  is_auction  Boolean?  @default(false)
  sale_price  Decimal?  @db.Decimal(10, 2)
  messages    messages[]
  cart_items  cart_items[]
  users       users     @relation("SellerItems", fields: [seller_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model messages {
  id          String    @id @default(uuid()) @db.Uuid
  item_id     String    @db.Uuid
  sender_id   String    @db.Uuid
  author_name String?   @db.VarChar(255)
  content     String    @db.Text
  attachments Json?     @default("[]") @db.JsonB
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  items       items     @relation(fields: [item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users       users     @relation(fields: [sender_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model cart_items {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String?   @db.Uuid
  product_id String?   @db.Uuid
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  items      items?    @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, product_id], map: "cart_items_user_id_product_id_key")
}

model user_activity {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String?   @db.Uuid
  action_type String    @db.VarChar(255)
  details    Json?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  page_url   String?   @db.VarChar(255)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model site_settings {
  id                  String   @id @default("main") @db.VarChar(255)
  key                 String   @unique @db.VarChar(255)
  hero_title          String?  @db.VarChar(255)
  hero_subtitle       String?  @db.VarChar(255)
  hero_image_url      String?  @db.VarChar(255)
  h_banner            Int?     @db.SmallInt
  news_banner_height  Int?     @db.SmallInt
  news_scroll_speed   Int?     @db.SmallInt
  catalog_min_columns Int?     @db.SmallInt
  catalog_max_card_width Int?  @db.SmallInt
  catalog_gap_px       Int?     @db.SmallInt
  catalog_card_padding_px Int? @db.SmallInt
  catalog_title_font_px Int?   @db.SmallInt
  catalog_text_font_px  Int?   @db.SmallInt
  agent_llm_model     String?  @db.VarChar(255)
  agent_mode          String?  @db.VarChar(50)
}

model news {
  id         String    @id @default(uuid()) @db.Uuid
  title      String?   @db.VarChar(255)
  body       String?   @db.Text
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  is_published Boolean? @default(true)
}

model testimonials {
  id          String    @id @default(uuid()) @db.Uuid
  author_name String?   @db.VarChar(255)
  text        String?   @db.Text
  is_active   Boolean?  @default(true)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  rating      Int?      @map("rating") @db.SmallInt
}

// Кэш промптов и ответов агента (для экономии токенов, поиска похожих запросов)
model agent_prompt_cache {
  id                String   @id @default(uuid()) @db.Uuid
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  user_account      String?  @db.VarChar(255)
  llm_model         String?  @db.VarChar(255)
  history_turns     Int      @default(0) @db.SmallInt
  project           String   @db.VarChar(128)
  environment       String   @db.VarChar(64)
  mode              String   @db.VarChar(16)
  chat_name         String?  @db.VarChar(255)
  topic             String?  @db.VarChar(128)
  prompt            String   @db.Text
  response          String   @db.Text
  file_links        String[] @default([])
  words_sent        Int      @default(0) @db.Integer
  words_received    Int      @default(0) @db.Integer
  prompt_hash       String?  @db.VarChar(64)
  system_prompt_len Int      @default(0) @db.Integer

  @@index([project, user_account, mode, llm_model])
  @@index([prompt_hash])
  @@index([topic])
  @@index([created_at])
}
